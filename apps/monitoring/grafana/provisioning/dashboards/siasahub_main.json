{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "panels": [
    {
      "title": "Total Requests per Service",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "title": "Average Response Latency (ms)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_sum[1m])) by (job) / sum(rate(http_request_duration_seconds_count[1m])) by (job) * 1000",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{code=~\"5..\"}[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "title": "Memory Usage (MB)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ],
  "schemaVersion": 26,
  "style": "dark",
  "tags": ["siasahub", "microservices"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "SiasaHub Main Dashboard",
  "uid": "siasahub_main",
  "version": 1
}
